DATABASE_URL=postgres://postgres:postgres@localhost:5432/darrow_ti
REDIS_URL=redis://localhost:6379
SESSION_SECRET=change-me-to-a-long-random-string
STORAGE_ROOT=/storage
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info
LIBREOFFICE_BIN=/usr/bin/libreoffice
PORT=4000
# Optional SMTP (Phase 17); SMTP_ENC_KEY must be 32 bytes (hex/base64) when smtp_enabled
SMTP_ENC_KEY=
# Optional: enables the no-login bill upload page at /upload?k=<token>. Leave blank to disable.
PUBLIC_UPLOAD_TOKEN=
